{
  "name": "@feanorfs/agent",
  "version": "0.3.3",
  "description": "Native Node bindings for FeanorFS agent workspaces",
  "main": "api.mjs",
  "types": "contract.d.ts",
  "exports": {
    ".": {
      "types": "./contract.d.ts",
      "import": "./api.mjs"
    },
    "./native": {
      "default": "./native.js"
    }
  },
  "files": [
    "api.mjs",
    "contract.d.ts",
    "index.js",
    "native.js"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rapm94/feanorfs.git",
    "directory": "bindings/ts"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "napi": {
    "name": "feanorfs-agent-node",
    "triples": {
      "defaults": false,
      "additional": [
        "x86_64-apple-darwin",
        "aarch64-apple-darwin",
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu",
        "x86_64-pc-windows-msvc"
      ]
    }
  },
  "scripts": {
    "build": "napi build --platform --release -p feanorfs-agent-node",
    "build:target": "napi build --release -p feanorfs-agent-node",
    "create-npm-dir": "napi create-npm-dir -t .",
    "assemble-packages": "node scripts/assemble-packages.mjs",
    "assemble-metadata": "node scripts/assemble-packages.mjs --metadata-only",
    "verify-packages": "node scripts/assemble-packages.mjs --verify",
    "verify-metadata": "node scripts/assemble-packages.mjs --verify --metadata-only",
    "publish-packages": "node scripts/publish-packages.mjs",
    "test:publish-packages": "node --test test/publish-packages.mjs",
    "test": "node test/loop.mjs"
  },
  "devDependencies": {
    "@napi-rs/cli": "2.18.4"
  },
  "license": "MIT",
  "optionalDependencies": {
    "@feanorfs/agent-darwin-x64": "0.3.3",
    "@feanorfs/agent-darwin-arm64": "0.3.3",
    "@feanorfs/agent-linux-x64-gnu": "0.3.3",
    "@feanorfs/agent-linux-arm64-gnu": "0.3.3",
    "@feanorfs/agent-win32-x64-msvc": "0.3.3"
  }
}
